{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "remote": {
    "urls": ["http://*:*"]
  },
  "permissions": [
    "default",
    "core:default",
    "shell:allow-open",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:window:allow-show"
  ]
}
